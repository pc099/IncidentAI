# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# S3 Configuration
LOG_BUCKET_NAME=incident-response-logs
KB_DATA_SOURCE_BUCKET_NAME=incident-response-kb-data

# DynamoDB Configuration
INCIDENT_TABLE_NAME=incident-history

# SES Configuration
SES_SENDER_EMAIL=incidents@example.com
SES_VERIFIED_DOMAIN=example.com

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
KB_NAME=incident-response-kb
KNOWLEDGE_BASE_ID=your-knowledge-base-id

# Lambda Configuration
LAMBDA_TIMEOUT=300
LAMBDA_MEMORY=512
