# Enhanced AI-Powered Incident Response System Configuration

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_HAIKU_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_KB_ID=your-knowledge-base-id
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Caching Configuration
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.90
CACHE_TTL_SECONDS=3600

# WebSocket Configuration
WEBSOCKET_ENDPOINT=wss://your-api-gateway-id.execute-api.us-east-1.amazonaws.com/prod
WEBSOCKET_CONNECTION_TIMEOUT_MINUTES=60

# Microsoft Teams Integration
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook-url
TEAMS_APPROVAL_CHANNEL=Incident Response
TEAMS_BOT_TOKEN=your-teams-bot-token

# Confidence Router Configuration
CONFIDENCE_HIGH_THRESHOLD=90.0
CONFIDENCE_MEDIUM_THRESHOLD=70.0
AUTONOMY_MODE=assisted
APPROVAL_TIMEOUT_MINUTES=30

# System Configuration
MAX_CONCURRENT_INCIDENTS=10
SESSION_TIMEOUT_MINUTES=60
LOG_LEVEL=INFO
ENABLE_METRICS=true
ENABLE_STREAMING=true

# DynamoDB Tables
INCIDENT_HISTORY_TABLE=enhanced-incident-history
APPROVAL_REQUESTS_TABLE=enhanced-approval-requests
CACHE_METADATA_TABLE=enhanced-cache-metadata

# S3 Configuration
LOG_BUCKET=your-incident-logs-bucket
KNOWLEDGE_BASE_BUCKET=your-kb-data-bucket

# CloudWatch Configuration
CLOUDWATCH_NAMESPACE=EnhancedIncidentResponse
ENABLE_DETAILED_MONITORING=true

# Security Configuration
ENCRYPTION_KEY_ID=your-kms-key-id
API_KEY=your-api-gateway-key

# Development Configuration
DEBUG=false
ENABLE_DEMO_MODE=true
DEMO_WEBSOCKET_PORT=8080